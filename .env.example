# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://url
POSTGRES_USER=user
POSTGRES_PASSWORD=root
POSTGRES_DB=gacs

# ─── API ────────────────────────────────────────────────
API_PORT=4000

# ─── Session ────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-64-char-string-in-production

# ─── Frontend URLs ──────────────────────────────────────
UI_URL=http://localhost:3000
REPORTING_URL=http://localhost:3001
MONITORING_URL=http://localhost:3002

# ─── CORS ─────────────────────────────────────────────
ALLOW_NGROK=true

# ─── Email (use Mailpit for local dev) ──────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gacs.local

# ─── GDPR ───────────────────────────────────────────────
DATA_RETENTION_DAYS=365
COOKIE_CONSENT_REQUIRED=true

# ─── Reporting ───────────────────────────────────────────
VITE_TINYMCE_API_KEY=xi8qvz8sdu4qdlw8wqbxy0xslyr7spi9cs5pxjoulhtr7w1x

# ─── Public URL (no trailing slash, no /api suffix) ─────
API_URL=http://YOUR_DROPLET_IP
UI_URL=http://YOUR_DROPLET_IP
REPORTING_URL=http://YOUR_DROPLET_IP
MONITORING_URL=http://YOUR_DROPLET_IP
